resource "unifi_user" "static_ips" {
  for_each = local.static_ip_assignments

  name     = each.value.name
  mac      = each.value.mac
  fixed_ip = each.value.fixed_ip

  lifecycle {
    prevent_destroy = true

    ignore_changes = [
      dev_id_override,
      local_dns_record,
      network_id,
    ]
  }
}
