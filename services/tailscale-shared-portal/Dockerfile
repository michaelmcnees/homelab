FROM golang:1.26-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/shared-portal ./cmd/shared-portal

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/shared-portal /shared-portal
USER nonroot:nonroot
ENTRYPOINT ["/shared-portal"]
